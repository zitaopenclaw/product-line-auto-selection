DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3

# FastAPI service (app.py) auth -- required, service returns 503 on every
# endpoint if unset. Copilot Studio sends this as the X-API-Key header.
APP_API_KEY=your_shared_api_key_here

# Optional: override where /feedback appends records (default: output/feedback/feedback.jsonl)
FEEDBACK_PATH=output/feedback/feedback.jsonl
